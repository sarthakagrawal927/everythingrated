{
  "name": "everythingrated",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @everythingrated/db generate",
    "db:push": "pnpm --filter @everythingrated/db push",
    "db:migrate": "pnpm --filter @everythingrated/db migrate",
    "db:studio": "pnpm --filter @everythingrated/db studio",
    "db:seed": "pnpm --filter @everythingrated/db seed"
  },
  "devDependencies": {
    "next": "16.2.4",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
